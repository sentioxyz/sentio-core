module(
    name = "sentio-core",
    version = "1.0",
)

# wasmer-go: sentioxyz fork consumed as a Bazel module (Bazel-9-ready), not go_deps
bazel_dep(name = "wasmer_go", version = "1.0.4")
git_override(
    module_name = "wasmer_go",
    commit = "477807e833107d0b0aa0203721c6c55cdf32fa6c",
    remote = "https://github.com/sentioxyz/wasmer-go",
)

# scip.proto is published in the root scip-code/scip repository, while this
# package only needs the single proto file for TypeScript generation.
http_file = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_file")

http_file(
    name = "scip_proto_download",
    downloaded_file_path = "scip.proto",
    sha256 = "387f91bea3357a6ab72ae6214c569bf33fddcd3c726a8eacfa1435d65ac347e8",
    urls = ["https://raw.githubusercontent.com/scip-code/scip/v0.7.1/scip.proto"],
)

