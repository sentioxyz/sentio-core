# Force google_benchmark >= 1.9.2: it drops the rules_foreign_cc dependency and
# pulls the foreign_cc-free libpfm@4.11.0.bcr.1 (rules_cc instead). Without this,
# the chain grpc -> opencensus-cpp -> google_benchmark@1.8.4 -> {rules_foreign_cc,
# libpfm} drags in rules_foreign_cc, whose old versions are incompatible with
# Bazel 9. Pinning google_benchmark high enough removes rules_foreign_cc from the
# graph entirely, so no rules_foreign_cc bazel_dep is needed.
# TODO When new grpc is released, remove this
bazel_dep(name = "google_benchmark", version = "1.9.5")
bazel_dep(name = "grpc", version = "1.81.0")

# grpc 1.81.0 pins envoy_api@20251216, which still imports the removed
# com_google_googleapis_imports repo and is incompatible with our pinned
# googleapis@20260525. Bump envoy_api to a version that dropped that reference.
bazel_dep(name = "envoy_api", version = "0.0.0-20260130-84e8436")
bazel_dep(name = "rules_proto_grpc", version = "5.8.0")
bazel_dep(name = "rules_proto_grpc_cpp", version = "5.8.0")
bazel_dep(name = "rules_proto_grpc_go", version = "5.8.0")
bazel_dep(name = "rules_proto_grpc_python", version = "5.8.0")
bazel_dep(name = "rules_proto_grpc_grpc_gateway", version = "5.8.0")
bazel_dep(name = "grpc_ecosystem_grpc_gateway", version = "2.29.0.bcr.3")
bazel_dep(name = "apple_support", version = "2.5.4", repo_name = "build_bazel_apple_support")

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = PTYHON_VERSION,
)

pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "core_pip",
    python_version = PTYHON_VERSION,
    requirements_darwin = "//:requirements_macos.txt",
    requirements_linux = "//:requirements_linux.txt",
)
use_repo(pip, "core_pip")

dev_pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
dev_pip.parse(
    hub_name = "core_pypi",
    python_version = PTYHON_VERSION,
    requirements_lock = "//tools:requirements.txt",
)
use_repo(dev_pip, "core_pypi")

