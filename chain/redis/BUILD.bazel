        "cache_test.go",
        "kv_store_test.go",
    ],
    embed = [":redis"],
    deps = [
        "//chain/chain",
        "//common/concurrency",
        "//common/range",
        "//common/set",
        "@com_github_alicebob_miniredis_v2//:miniredis",
        "@com_github_redis_go_redis_v9//:go-redis",
        "@com_github_stretchr_testify//assert",
    ],
