load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "redis",
    srcs = [
        "cache.go",
        "kv_store.go",
    ],
    importpath = "sentioxyz/sentio-core/chain/redis",
    visibility = ["//visibility:public"],
    deps = [
        "//chain/chain",
        "//common/concurrency",
