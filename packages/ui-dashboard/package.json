{
  "private": false,
  "name": "@sentio/ui-dashboard",
  "version": "0.3.5",
  "description": "Dashboard UI components for the Sentio platform, decoupled from backend services.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:css && pnpm build:js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/style.css --minify",
    "build:js": "tsup",
    "clean": "rm -rf dist",
    "dev": "concurrently \"pnpm:dev:css\" \"pnpm:dev:js\"",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./dist/style.css --watch",
    "dev:js": "tsup --watch",
    "ladle": "pnpm build:css && ladle serve",
    "publish:npm": "pnpm build && pnpm publish --access public --no-git-checks"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "dist/index.d.ts",
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@headlessui/react": "1.7.7",
    "@sentio/bigdecimal": "9.1.1-patch.3",
    "@sentio/chain": "workspace:^",
    "@sentio/ui-core": "workspace:^",
    "echarts": "^6.0.0",
    "immer": "^11.1.8",
    "lodash": "^4.17.21",
    "react-icons": "^5.5.0",
    "react-resize-detector": "^12.3.0"
  },
  "peerDependencies": {
    "dayjs": ">=1.11",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/lodash": "^4.17.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.2",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
