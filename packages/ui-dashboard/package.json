{
  "private": false,
  "name": "@sentio/ui-dashboard",
  "version": "0.0.1",
  "description": "Dashboard UI components for the Sentio platform, decoupled from backend services.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:css && pnpm build:js",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/style.css --minify",
    "build:js": "tsup",
    "clean": "rm -rf dist",
    "dev": "concurrently \"pnpm:dev:css\" \"pnpm:dev:js\"",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./dist/style.css --watch",
    "dev:js": "tsup --watch",
    "publish:npm": "pnpm build && npm publish --access public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "dist/index.d.ts",
  "dependencies": {
    "@sentio/ui-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
